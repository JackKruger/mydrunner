{
  "name": "mydrunner",
  "version": "0.0.0",
  "private": true,
  "description": "Browser-based multiplayer off-road physics game (MudRunner-inspired)",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter './packages/*' run dev",
    "dev:server": "pnpm --filter @mydrunner/server run dev",
    "dev:client": "pnpm --filter @mydrunner/client run dev",
    "build": "pnpm -r --filter './packages/*' run build",
    "typecheck": "pnpm -r --filter './packages/*' run typecheck",
    "test": "pnpm -r --filter './packages/*' run test",
    "test:e2e": "pnpm --filter @mydrunner/e2e run test",
    "lint": "pnpm -r --filter './packages/*' run lint",
    "clean": "pnpm -r exec rm -rf dist node_modules/.vite .turbo"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
